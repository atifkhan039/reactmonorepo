{
    "compilerOptions": {
      "target": "es2023",
      "module": "esnext",
      "moduleResolution": "bundler",
      "strict": true,
      "skipLibCheck": true,
      "verbatimModuleSyntax": true,
      "moduleDetection": "force",
      "noEmit": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true
    }
}